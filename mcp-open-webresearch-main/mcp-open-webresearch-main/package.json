{
  "name": "mcp-open-websearch",
  "version": "0.0.1",
  "description": "web search the internet",
  "type": "module",
  "bin": {
    "open-websearch": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "start": "node build/index.js",
    "start:proxy": "./launch-proxy.sh",
    "test": "vitest run",
    "test:debug": "vitest run --test-timeout=0 --no-file-parallelism"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@types/axios": "^0.14.4",
    "@types/cheerio": "^1.0.0",
    "@types/node": "^24.9.2",
    "@types/turndown": "^5.0.6",
    "axios": "^1.13.1",
    "cheerio": "^1.1.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "https-proxy-agent": "^7.0.6",
    "jsdom": "^26.1.0",
    "playwright": "^1.56.1",
    "socks-proxy-agent": "^8.0.5",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsdom": "^27.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.5"
  }
}